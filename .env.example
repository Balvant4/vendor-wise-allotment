# ─── Database ─────────────────────────────────────────────
# MongoDB Atlas (or self-hosted) connection string.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db-name>

# ─── Auth ─────────────────────────────────────────────────
# Generate strong random values, e.g.:  openssl rand -base64 48
# Never reuse these across environments (dev/staging/prod should each
# have their own), and never commit real values to source control.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
NODE_ENV=production

# ─── Upload ───────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALERT_THRESHOLD_HOURS=25

# ─── Email (SLA violation notifications) ───────────────────
# Any SMTP provider works (SendGrid, Postmark, SES SMTP, Gmail app password).
# If left unset, emails are skipped (logged only) — in-app notifications
# still work regardless of whether SMTP is configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vendor Control Tower <no-reply@yourcompany.com>"

# ─── Seed script (optional) ────────────────────────────────
# Only used by `server/actions/seed.ts` to create the first admin account.
# If SEED_ADMIN_PASSWORD is left unset, a random password is generated and
# printed once when the script runs — copy it immediately.
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=
